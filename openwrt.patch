diff --git a/target/linux/bcm27xx/base-files/etc/init.d/bluetooth-hci b/target/linux/bcm27xx/base-files/etc/init.d/bluetooth-hci
new file mode 100755
index 0000000000..fe6ec02c60
--- /dev/null
+++ b/target/linux/bcm27xx/base-files/etc/init.d/bluetooth-hci
@@ -0,0 +1,22 @@
+#!/bin/sh /etc/rc.common
+
+START=95
+STOP=10
+
+USE_PROCD=1
+
+start_service() {
+    modprobe btbcm
+    modprobe hci_uart
+    sleep 2
+
+    procd_open_instance
+    procd_set_param command /usr/bin/btattach -B /dev/ttyAMA1 -S 3000000 -P bcm
+    procd_set_param respawn
+    procd_set_param stdout 1
+    procd_set_param stderr 1
+    procd_close_instance
+
+    sleep 3
+    hciconfig hci0 up
+}
diff --git a/target/linux/bcm27xx/base-files/etc/init.d/custom-setup b/target/linux/bcm27xx/base-files/etc/init.d/custom-setup
new file mode 100755
index 0000000000..a4cab4476e
--- /dev/null
+++ b/target/linux/bcm27xx/base-files/etc/init.d/custom-setup
@@ -0,0 +1,40 @@
+#!/bin/sh /etc/rc.common
+
+START=99
+STOP=01
+
+FLAG=/etc/.custom_setup_done
+
+start() {
+    [ -f "$FLAG" ] && exit 0
+
+    # wait for phy1 to enumerate (USB/slow-probe radios)
+    for i in $(seq 1 60); do
+        [ -d /sys/class/ieee80211/phy1 ] && break
+        sleep 1
+    done
+    [ -d /sys/class/ieee80211/phy1 ] || {
+        logger -t custom-setup "phy1 never appeared, aborting"
+        exit 1
+    }
+
+    # generate the radio1 UCI section if it doesn't exist yet
+    if ! uci -q get wireless.radio1 >/dev/null; then
+        wifi detect >> /etc/config/wireless
+    fi
+
+    uci set wireless.radio1.htmode='HT20'
+    uci set wireless.radio1.band='2g'
+    uci set wireless.radio1.channel='auto'
+    uci set wireless.radio1.cell_density='0'
+    uci set wireless.radio1.disabled='0'
+    uci set wireless.default_radio1.ssid='FKM-Comp'
+    uci set wireless.default_radio1.encryption='psk2'
+    uci set wireless.default_radio1.key='Competition'
+    uci set wireless.default_radio1.disabled='0'
+    uci commit wireless
+    wifi up radio1
+
+    touch "$FLAG"
+    logger -t custom-setup "initial configuration applied"
+}
