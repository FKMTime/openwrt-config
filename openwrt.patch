--- /dev/null
+++ b/target/linux/bcm27xx/base-files/etc/uci-defaults/99-eth-wifi-default
@@ -0,0 +1,109 @@
+# /etc/config/uhttpd
+uci delete uhttpd.main.listen_http
+uci add_list uhttpd.main.listen_http='0.0.0.0:81'
+uci add_list uhttpd.main.listen_http='[::]:81'
+
+# /etc/config/dhcp
+uci del dhcp.lan.ra_slaac
+uci set dhcp.lan.ra_preference='medium'
+
+# /etc/config/firewall
+uci add firewall forwarding # =cfg0fad58
+uci set firewall.@forwarding[-1].src='docker'
+uci set firewall.@forwarding[-1].dest='wan'
+
+uci add firewall redirect # =cfg103837
+uci set firewall.@redirect[-1].dest='lan'
+uci set firewall.@redirect[-1].target='DNAT'
+uci set firewall.@redirect[-1].name='web'
+uci set firewall.@redirect[-1].src='wan'
+uci set firewall.@redirect[-1].src_dport='80'
+uci set firewall.@redirect[-1].dest_ip='192.168.3.1'
+uci set firewall.@redirect[-1].dest_port='80'
+
+uci add firewall redirect # =cfg133837
+uci set firewall.@redirect[-1].dest='lan'
+uci set firewall.@redirect[-1].target='DNAT'
+uci set firewall.@redirect[-1].name='web2'
+uci set firewall.@redirect[-1].src='wan'
+uci set firewall.@redirect[-1].src_dport='81'
+uci set firewall.@redirect[-1].dest_ip='192.168.3.1'
+uci set firewall.@redirect[-1].dest_port='81'
+
+uci add firewall rule # =cfg1192bd
+uci set firewall.@rule[-1].src='wan'
+uci set firewall.@rule[-1].name='Allow-SSH-WAN'
+uci set firewall.@rule[-1].dest_port='22'
+uci set firewall.@rule[-1].target='ACCEPT'
+
+uci del firewall.cfg03dc81.network
+uci add_list firewall.cfg03dc81.network='wan'
+uci add_list firewall.cfg03dc81.network='wan6'
+uci add_list firewall.cfg03dc81.network='wwan'
+
+uci add firewall redirect # =cfg123837
+uci set firewall.@redirect[-1].dest='lan'
+uci set firewall.@redirect[-1].target='DNAT'
+uci set firewall.@redirect[-1].name='fim'
+uci set firewall.@redirect[-1].src='wan'
+uci set firewall.@redirect[-1].src_dport='8181'
+uci set firewall.@redirect[-1].dest_ip='192.168.3.1'
+uci set firewall.@redirect[-1].dest_port='8181'
+
+
+# /etc/config/network
+uci add network device # =cfg070f15
+uci set network.@device[-1].type='bridge'
+uci set network.@device[-1].name='bridge-lan'
+uci set network.@device[-1].bridge_empty='1'
+uci del network.cfg030f15
+uci set network.globals.packet_steering='1'
+uci set network.lan.device='bridge-lan'
+uci del network.lan.ipaddr
+uci add_list network.lan.ipaddr='192.168.3.1/24'
+uci set network.lan.multipath='off'
+uci set network.wan=interface
+uci set network.wan.proto='dhcp'
+uci set network.wan.device='eth0'
+uci set network.wan.peerdns='0'
+uci add_list network.wan.dns='1.1.1.1'
+uci set network.wan.multipath='off'
+
+uci set network.wwan=interface
+uci set network.wwan.proto='none'
+uci set network.wwan.proto='dhcp'
+uci set network.wwan.device='phy0-sta0'
+
+
+# docker setup
+uci set dockerd.firewall.extra_iptables_args='--match conntrack ! --ctstate RELATED,ESTABLISHED'
+
+if ! uci -q get firewall.docker >/dev/null; then
+    uci add firewall zone
+    uci rename firewall.@zone[-1]='docker'
+    uci set firewall.docker.name='docker'
+    uci set firewall.docker.input='ACCEPT'
+    uci set firewall.docker.output='ACCEPT'
+    uci set firewall.docker.forward='ACCEPT'
+fi
+
+uci add_list firewall.docker.device='br-*'
+
+# /etc/config/wireless
+uci set wireless.radio0.htmode='HT20'
+uci set wireless.radio0.band='2g'
+uci set wireless.radio0.channel='auto'
+uci set wireless.radio0.cell_density='0'
+uci set wireless.default_radio0.mode='sta'
+uci set wireless.default_radio0.ssid='Client'
+uci set wireless.default_radio0.encryption='psk2'
+uci set wireless.default_radio0.key='password'
+uci set wireless.default_radio0.network='wwan'
+uci set wireless.radio0.disabled='0'
+uci set wireless.default_radio0.disabled='0'
+
+uci commit
+wifi up radio0
+/etc/init.d/uhttpd restart
+
+exit 0
